# ============================================================================
# HorseMod — .gitignore
# ============================================================================

# --- Build outputs ----------------------------------------------------------
build_cmake_*/
build/
out/
target/              # Rust (RE-UE4SS has patternsleuth crate)
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
# Persistent FetchContent cache (glaze/glfw/imgui/zydis/polyhook2/fmt/...).
# Set as FETCHCONTENT_BASE_DIR in the root CMakeLists so deps survive a
# nuked build dir.  Pure cache — regenerable from the GIT_REPOSITORY/GIT_TAG
# pairs in RE-UE4SS/deps/third/CMakeLists.txt.
.fetched_deps/

# --- Intermediate / object files -------------------------------------------
*.o
*.obj
*.pdb
*.ilk
*.exp
*.idb
*.ipdb
*.iobj
*.tlog
*.res
*.rsp

# --- Binaries (we don't ship the .dll from the repo; CI or local build) ----
*.dll
*.exe
*.lib
*.pyc
__pycache__/

# Exception: keep third-party vendored import libs shipped by RE-UE4SS
# (GLFW pre-built archives).
!RE-UE4SS/deps/third/GLFW/lib-vc2022/*.lib

# --- Ghidra scratch dumps (local investigation output) ---------------------
_decomp_tmp.c
_tmp_func.c
decomp.c
*.ghidra_dump.c

# --- IDE / editor metadata --------------------------------------------------
.vs/
.vscode/
.idea/
# Claude Code runtime state (scheduled_tasks.lock etc.)
.claude/
*.suo
*.user
*.vcxproj.filters
*.swp
*~

# --- OS metadata ------------------------------------------------------------
.DS_Store
Thumbs.db

# --- Logs / temp ------------------------------------------------------------
*.log
tmp/

# --- Release artifacts ------------------------------------------------------
# Output of build_release_github.bat / build_release_thunderstore.bat —
# the zips are uploaded to GitHub Releases / Thunderstore, not committed
# back to the repo.
dist/

# --- Game data dump (research only, not redistributable) -------------------
# Local copy of SC6 character data (chr*.mot, atkhit*.dat, hdr*.khd,
# CP_*.uasset, cpuai*.dtp) used to reverse-engineer move bytecode for the
# multi-hit-step bug investigation.  Do NOT commit — licensed game assets.
# Regenerable from a local UnrealPak dump.
dump/
